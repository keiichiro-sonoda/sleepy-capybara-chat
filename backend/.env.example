# アプリケーション設定
PROJECT_NAME=Sleepy Capybara Chat
API_V1_STR=/api/v1

# JWT設定
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin123

EMAIL_SERVICE=sendgrid  # "mailhog", "sendgrid", or "gmail"

# SendGrid設定（廃止予定）
MAIL_FROM=no-reply@sleepycapybara.org  # SendGridで検証済みのメールアドレス
SENDGRID_API_KEY=your_sendgrid_api_key_here  # SendGridダッシュボードから取得

# Gmail SMTP設定
GMAIL_USER=your-email@gmail.com
GMAIL_APP_PASSWORD=your-16-digit-app-password

# ログレベル設定
LOG_LEVEL=INFO

OPENAI_API_KEY=your_api_key
