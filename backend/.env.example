# アプリケーション設定
PROJECT_NAME=Sleepy Capybara Chat
API_V1_STR=/api/v1

# JWT設定
JWT_SECRET_KEY=dev_secret_key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# データベース接続情報（Docker Compose環境）
# 実際の値はルートの.envから取得されます
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgrespassword
POSTGRES_DB=capybara_chat
POSTGRES_HOST=db
POSTGRES_PORT=5432

ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin123

EMAIL_SERVICE=sendgrid  # "mailhog", "sendgrid", or "gmail"

# SendGrid設定（廃止予定）
MAIL_FROM=no-reply@sleepycapybara.org  # SendGridで検証済みのメールアドレス
SENDGRID_API_KEY=your_sendgrid_api_key_here  # SendGridダッシュボードから取得

# Gmail SMTP設定
GMAIL_USER=your-email@gmail.com
GMAIL_APP_PASSWORD=your-16-digit-app-password

# フロントエンドURL（メール認証リンク用）
FRONTEND_URL=http://localhost:3000

# ログレベル設定
LOG_LEVEL=INFO

# CORS設定
# 本番環境では Cloudflare Tunnel のオリジンを追加
CORS_ORIGINS='["http://localhost:3000"]'

OPENAI_API_KEY=your_api_key
