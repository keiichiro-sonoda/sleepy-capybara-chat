# アプリケーション設定
PROJECT_NAME=Sleepy Capybara Chat
API_V1_STR=/api/v1

# JWT設定
JWT_SECRET_KEY=dev_secret_key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# データベース接続情報（Docker Compose環境）
# 実際の値はルートの.envから取得されます
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgrespassword
POSTGRES_DB=capybara_chat
POSTGRES_HOST=db
POSTGRES_PORT=5432

# メール設定
MAIL_USERNAME=test@example.com
MAIL_PASSWORD=test_password
MAIL_FROM=noreply@capybarachat.com
MAIL_PORT=1025
MAIL_SERVER=mailhog
MAIL_SSL_TLS=False
MAIL_STARTTLS=False

# フロントエンドURL（メール認証リンク用）
FRONTEND_URL=http://localhost:3000

# ログレベル設定
LOG_LEVEL=INFO
